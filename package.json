{
  "name": "firestore-rules-testing",
  "version": "1.0.0",
  "description": "Firestore Security Rules Testing",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "emulator:start": "firebase emulators:start --only firestore",
    "emulator:test": "firebase emulators:exec --only firestore 'sleep 3 && npm test'",
    "emulator:test:ci": "firebase emulators:exec --only firestore --project demo-test 'sleep 5 && npm test'",
    "functions:build": "npm --prefix functions run build",
    "functions:lint": "npm --prefix functions run lint",
    "functions:test": "npm --prefix functions run test:node20",
    "deploy:functions:dev": "npm --prefix functions run deploy:functions:dev",
    "deploy:functions:prod": "npm --prefix functions run deploy:functions:prod",
    "deploy:rules:dev": "npm --prefix functions run deploy:rules:dev",
    "deploy:rules:prod": "npm --prefix functions run deploy:rules:prod",
    "deploy:indexes:dev": "npm --prefix functions run deploy:indexes:dev",
    "deploy:indexes:prod": "npm --prefix functions run deploy:indexes:prod",
    "logs:functions:dev": "npm --prefix functions run logs:dev",
    "logs:functions:prod": "npm --prefix functions run logs:prod"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.3",
    "jest": "^29.7.0",
    "firebase": "^10.7.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000,
    "maxWorkers": 1,
    "forceExit": true,
    "detectOpenHandles": true
  }
}
