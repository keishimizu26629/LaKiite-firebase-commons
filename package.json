{
  "name": "firestore-rules-testing",
  "version": "1.0.0",
  "description": "Firestore Security Rules Testing",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "emulator:start": "firebase emulators:start --only firestore",
    "emulator:test": "firebase emulators:exec --only firestore 'npm test'"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.3",
    "jest": "^29.7.0",
    "firebase": "^10.7.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
